<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("../partials/head") %>
</head>
<body>
  <%- include("../partials/header") %>

  <main class="page">
    <section class="page-card">
      <h1><%= title %></h1>

      <form method="post" action="<%= action %>">
        <p>
          <label>
            Name<br>
            <input type="text" name="name" value="<%= location.name || "" %>" required>
          </label>
        </p>

        <p>
          <label>
            Description<br>
            <textarea name="description"><%= location.description || "" %></textarea>
          </label>
        </p>

        <p>
          <label>
            Latitude<br>
            <input type="number" step="0.0000001" name="latitude" value="<%= location.latitude || "" %>">
          </label>
        </p>

        <p>
          <label>
            Longitude<br>
            <input type="number" step="0.0000001" name="longitude" value="<%= location.longitude || "" %>">
          </label>
        </p>

        <button type="submit">Save</button>
        <a href="/locations">Cancel</a>
      </form>
    </section>
  </main>

  <%- include("../partials/footer") %>
</body>
</html>